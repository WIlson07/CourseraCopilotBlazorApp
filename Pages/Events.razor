@page "/"
@page "/events"
@inject NavigationManager NavigationManager
@inject EventService EventService

<PageTitle>Events</PageTitle>

<h1>Upcoming Events</h1>
<p class="lead">Browse our upcoming events and register for the ones that interest you.</p>

<div class="row">
    @foreach (var eventItem in events)
    {
        <div class="col-md-6 col-lg-4" @key="eventItem.Id">
            <EventCard 
                Event="@eventItem"
                OnViewDetails="@HandleViewDetails" />
        </div>
    }
</div>

@code {
    private IReadOnlyList<EventItem> events = Array.Empty<EventItem>();

    protected override void OnInitialized()
    {
        events = EventService.GetUpcomingEvents();
    }

    private void HandleViewDetails(int eventId)
    {
        NavigationManager.NavigateTo($"/events/{eventId}");
    }
}
